<div class="relative isolate overflow-hidden">
  <div class="mx-auto max-w-6xl px-8">
    {{#if statusMessage}}
      <div
        class="mb-6 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 shadow-sm"
      >
        {{statusMessage}}
      </div>
    {{/if}}

    {{#if errorMessage}}
      <div
        class="mb-6 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700 shadow-sm"
      >
        {{errorMessage}}
      </div>
    {{/if}}

    <div class="grid gap-8 lg:grid-cols-2">
      <section
        class="rounded-[28px] border border-[#755e3a24] bg-[#fffdf9cc] p-6"
      >
        <div class="mb-6 flex items-end justify-between gap-4">
          <div>
            <p
              class="text-xs font-semibold uppercase tracking-[0.24em] text-[#7c6a59]"
            >Quick entry</p>
            <h2 class="mt-2 text-2xl font-semibold text-[#201a16]">Add a task</h2>
          </div>
        </div>

        <form method="POST" action="/dashboard" class="space-y-5">
          <div class="space-y-2">
            <label
              for="title"
              class="text-sm font-medium text-[#201a16]"
            >Title</label>
            <input
              type="text"
              id="title"
              name="title"
              required
              autofocus
              placeholder="e.g., Do the laundry"
              class="w-full rounded-2xl border border-[#755e3a2a] bg-white/90 px-4 py-3 text-[#201a16] outline-none transition duration-200 placeholder:text-[#988b81] focus:border-[#bb5a3c] focus:ring-4 focus:ring-[#bb5a3c1a]"
            />
          </div>

          <div class="space-y-2">
            <label
              for="description"
              class="text-sm font-medium text-[#201a16]"
            >Description</label>
            <textarea
              id="description"
              name="description"
              rows="5"
              placeholder="Add a few details"
              class="w-full rounded-2xl border border-[#755e3a2a] bg-white/90 px-4 py-3 text-[#201a16] outline-none transition duration-200 placeholder:text-[#988b81] focus:border-[#bb5a3c] focus:ring-4 focus:ring-[#bb5a3c1a]"
            ></textarea>
          </div>

          <div class="space-y-2">
            <label for="dueDate" class="text-sm font-medium text-[#201a16]">Due
              date</label>
            <input
              type="date"
              id="dueDate"
              name="dueDate"
              class="w-full rounded-2xl border border-[#755e3a2a] bg-white/90 px-4 py-3 text-[#201a16] outline-none transition duration-200 focus:border-[#bb5a3c] focus:ring-4 focus:ring-[#bb5a3c1a]"
            />
          </div>

          <button
            type="submit"
            class="inline-flex w-full items-center justify-center rounded-2xl bg-[#bb5a3c] px-5 py-3.5 text-sm font-semibold text-white transition duration-200 hover:-translate-y-0.5 hover:bg-[#a94e34] focus:outline-none focus:ring-4 focus:ring-[#bb5a3c33]"
          >
            Create task
          </button>
        </form>
      </section>

      <section
        class="rounded-[28px] border border-[#755e3a24] bg-[#201a16] p-6 text-[#f8f3eb] sm:p-8"
      >
        <div class="mb-6 flex flex-wrap items-end justify-between gap-4">
          <div>
            <p
              class="text-xs font-semibold uppercase tracking-[0.24em] text-[#d8c8b5]"
            >Task list</p>
            <h2 class="mt-2 text-2xl font-semibold text-white">Your tasks</h2>
          </div>
          <p
            class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-sm text-[#efe6d8]"
          >{{tasks.length}} total</p>
        </div>

        {{#if hasTasks}}
          <div class="max-h-[48vh] space-y-4 overflow-y-auto pr-2">
            {{#each tasks}}
              <article
                class="rounded-[24px] border border-white/10 bg-white/6 p-5 transition duration-200 hover:-translate-y-0.5 hover:border-white/20 hover:bg-white/8"
              >
                <div class="flex items-start justify-between gap-4">
                  <div class="min-w-0 space-y-1">
                    <h3
                      class="text-lg font-semibold text-white"
                    >{{this.title}}</h3>
                    {{#if this.dueDate}}
                      <p class="text-sm text-[#d7c8ba]">Due
                        {{formatDate this.dueDate}}</p>
                    {{else}}
                      <p class="text-sm text-[#d7c8ba]">No due date set</p>
                    {{/if}}
                  </div>
                  {{#if this.completed}}
                    <span
                      class="shrink-0 rounded-full bg-emerald-500/15 px-3 py-1 text-xs font-semibold text-emerald-300"
                    >Done</span>
                  {{else}}
                    <span
                      class="shrink-0 rounded-full bg-amber-500/15 px-3 py-1 text-xs font-semibold text-amber-200"
                    >Open</span>
                  {{/if}}
                </div>

                <p class="mt-4 text-sm leading-6 text-[#efe6d8]">
                  {{#if this.description}}{{this.description}}{{else}}No
                    description yet.{{/if}}
                </p>

                <div class="mt-5 flex items-center justify-between gap-3">
                  <div class="flex flex-wrap items-center gap-3">
                    <a
                      href="/task/{{this._id}}"
                      class="inline-flex items-center rounded-full border border-white/15 bg-white/10 px-4 py-2 text-sm font-medium text-white transition duration-200 hover:border-white/25 hover:bg-white/15"
                    >
                      Edit
                    </a>
                    <form
                      method="POST"
                      action="/task/{{this._id}}/delete"
                      class="my-auto"
                    >
                      <button
                        type="submit"
                        class="inline-flex items-center rounded-full border border-[#f2b8a2]/20 bg-[#bb5a3c] px-4 py-2 text-sm font-medium text-white transition duration-200 hover:bg-[#a94e34]"
                      >
                        Delete
                      </button>
                    </form>
                  </div>

                  <form
                    method="POST"
                    action="/task/{{this._id}}/update"
                    class="my-auto"
                  >
                    <input type="hidden" name="title" value="{{this.title}}" />
                    <input
                      type="hidden"
                      name="description"
                      value="{{this.description}}"
                    />
                    <input
                      type="hidden"
                      name="dueDate"
                      value="{{formatDateInput this.dueDate}}"
                    />
                    <input type="hidden" name="completed" value="true" />
                    <button
                      type="submit"
                      class="inline-flex items-center rounded-full border border-emerald-300/20 bg-emerald-500/15 px-4 py-2 text-sm font-medium text-emerald-200 transition duration-200 hover:bg-emerald-500/25 hover:text-white"
                    >
                      Complete
                    </button>
                  </form>
                </div>
              </article>
            {{/each}}
          </div>
        {{else}}
          <div
            class="rounded-[24px] border border-dashed border-white/15 bg-white/5 p-8 text-center"
          >
            <p class="text-lg font-medium text-white">You have no tasks yet.</p>
            <p class="mt-2 text-sm leading-6 text-[#d7c8ba]">Add your first task
              on the left to start building momentum.</p>
          </div>
        {{/if}}
      </section>
    </div>
  </div>
</div>