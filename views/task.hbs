<div class="relative overflow-hidden">
  <div class="mx-auto max-w-6xl space-y-8 px-8">
    {{#if errorMessage}}
      <div
        class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700 shadow-sm"
      >
        {{errorMessage}}
      </div>
    {{/if}}

    <section
      class="overflow-hidden rounded-[32px] border border-[#755e3a24] bg-[#fffaf4cc]"
    >
      <div class="grid grid-cols-2">
        <div
          class="border-b border-[#755e3a1e] bg-[#201a16] text-[#f8f3eb] border-r border-[#755e3a1e] p-10"
        >
          <div class="space-y-5">
            <div class="flex flex-wrap items-center gap-3">
              <span
                class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold uppercase tracking-[0.22em] text-[#d8c8b5]"
              >Task detail</span>
              {{#if task.completed}}
                <span
                  class="inline-flex items-center rounded-full bg-emerald-500/15 px-3 py-1 text-xs font-semibold text-emerald-300"
                >Completed</span>
              {{else}}
                <span
                  class="inline-flex items-center rounded-full bg-amber-500/15 px-3 py-1 text-xs font-semibold text-amber-200"
                >In progress</span>
              {{/if}}
            </div>

            <div class="space-y-3">
              <h1
                class="font-serif text-4xl font-semibold tracking-tight text-white"
              >{{task.title}}</h1>
              <p class="max-w-xl text-base leading-7 text-[#d7c8ba]">
                {{#if task.dueDate}}
                  Due
                  {{formatDate task.dueDate}}
                {{else}}
                  No due date set yet.
                {{/if}}
              </p>
            </div>

            <div class="grid gap-3 grid-cols-2">
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                <p
                  class="text-xs font-semibold uppercase tracking-[0.22em] text-[#d8c8b5]"
                >Created</p>
                <p class="mt-2 text-sm text-white">{{formatDate
                    task.createdAt
                  }}</p>
              </div>
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                <p
                  class="text-xs font-semibold uppercase tracking-[0.22em] text-[#d8c8b5]"
                >Updated</p>
                <p class="mt-2 text-sm text-white">
                  {{#if task.updatedAt}}
                    {{formatDate task.updatedAt}}
                  {{else}}
                    Not updated yet
                  {{/if}}
                </p>
              </div>
            </div>

            <div class="rounded-[24px] border border-white/10 bg-white/5 p-5">
              <p
                class="text-xs font-semibold uppercase tracking-[0.22em] text-[#d8c8b5]"
              >Description</p>
              <p class="mt-3 text-sm leading-7 text-[#f1e8dc]">
                {{#if task.description}}
                  {{task.description}}
                {{else}}
                  No description provided.
                {{/if}}
              </p>
            </div>

            <div class="flex flex-wrap items-center gap-3">
              <a
                href="/dashboard"
                class="inline-flex items-center rounded-full border border-white/15 bg-white/10 px-4 py-2 text-sm font-medium text-white transition duration-200 hover:border-white/25 hover:bg-white/15"
              >
                ← Back to Dashboard
              </a>
              <form
                method="POST"
                action="/task/{{task._id}}/delete"
                class="my-auto"
              >
                <button
                  type="submit"
                  class="inline-flex items-center rounded-full border border-[#f2b8a2]/20 bg-[#bb5a3c] px-4 py-2 text-sm font-medium text-white transition duration-200 hover:bg-[#a94e34]"
                >
                  Delete
                </button>
              </form>
            </div>
          </div>
        </div>

        <div class="p-6 sm:p-8 lg:p-10">
          <div class="mb-6 flex items-end justify-between gap-4">
            <div>
              <p
                class="text-xs font-semibold uppercase tracking-[0.24em] text-[#7c6a59]"
              >Edit mode</p>
              <h2 class="mt-2 text-2xl font-semibold text-[#201a16]">Update task</h2>
            </div>
          </div>

          <form
            method="POST"
            action="/task/{{task._id}}/update"
            class="space-y-5"
          >
            <div class="space-y-2">
              <label
                for="title"
                class="text-sm font-medium text-[#201a16]"
              >Title</label>
              <input
                type="text"
                id="title"
                name="title"
                required
                value="{{task.title}}"
                class="w-full rounded-2xl border border-[#755e3a2a] bg-white/90 px-4 py-3 text-[#201a16] outline-none transition duration-200 placeholder:text-[#988b81] focus:border-[#bb5a3c] focus:ring-4 focus:ring-[#bb5a3c1a]"
              />
            </div>

            <div class="space-y-2">
              <label
                for="description"
                class="text-sm font-medium text-[#201a16]"
              >Description</label>
              <textarea
                id="description"
                name="description"
                rows="7"
                class="w-full rounded-2xl border border-[#755e3a2a] bg-white/90 px-4 py-3 text-[#201a16] outline-none transition duration-200 placeholder:text-[#988b81] focus:border-[#bb5a3c] focus:ring-4 focus:ring-[#bb5a3c1a]"
              >{{task.description}}</textarea>
            </div>

            <div class="space-y-2">
              <label
                for="dueDate"
                class="text-sm font-medium text-[#201a16]"
              >Due date</label>
              <input
                type="date"
                id="dueDate"
                name="dueDate"
                value="{{formatDateInput task.dueDate}}"
                class="w-full rounded-2xl border border-[#755e3a2a] bg-white/90 px-4 py-3 text-[#201a16] outline-none transition duration-200 focus:border-[#bb5a3c] focus:ring-4 focus:ring-[#bb5a3c1a]"
              />
            </div>

            <label class="flex items-center gap-3">
              {{#if task.completed}}
                <input type="checkbox" name="completed" value="true" checked />
              {{else}}
                <input type="checkbox" name="completed" value="true" />
              {{/if}}
              <span>Mark as completed</span>
            </label>

            <div class="flex flex-wrap gap-3 pt-2">
              <button
                type="submit"
                class="inline-flex items-center justify-center rounded-2xl bg-[#bb5a3c] px-5 py-3 text-sm font-semibold text-white transition duration-200 hover:bg-[#a94e34] focus:outline-none focus:ring-4 focus:ring-[#bb5a3c33]"
              >
                Save changes
              </button>
              <a
                href="/dashboard"
                class="inline-flex items-center justify-center rounded-2xl border border-[#755e3a2a] bg-white/80 px-5 py-3 text-sm font-semibold text-[#201a16] shadow-sm transition duration-200 hover:border-[#bb5a3c33] hover:text-[#bb5a3c]"
              >
                Cancel
              </a>
            </div>
          </form>
        </div>
      </div>
    </section>
  </div>
</div>