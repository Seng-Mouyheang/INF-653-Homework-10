<div class="pt-12">
  <div
    class="mx-auto max-w-[500px] rounded-[24px] border border-[#755e3a2e] bg-[#ffffffb8] p-10 text-[#201a16] shadow-xl"
  >
    <div class="mb-8 text-center">
      <h2 class="m-0 text-2xl font-bold">Register</h2>
      <p class="mt-2 text-[#5c5149]">Please fill out the form below to create an
        account.</p>
    </div>
    {{#if errorMessage}}
      <div
        class="mb-6 rounded-lg bg-red-100 p-4 text-sm text-red-700 border border-red-200"
      >
        {{errorMessage}}
      </div>
    {{/if}}

    <form action="/register" method="POST" class="space-y-6">

      <div class="text-left">
        <label
          for="email"
          class="mb-2 block text-sm font-medium text-[#201a16]"
        >
          Email:
        </label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="e.g., john.doe@example.com"
          required
          class="w-full rounded-xl border border-[ #755e3a2e] bg-[#ffffffb8] p-3 text-[#201a16] transition-colors duration-200 focus:border-[#bb5a3c] focus:outline-none"
        />
      </div>

      <div class="text-left">
        <label
          for="password"
          class="mb-2 block text-sm font-medium text-[#201a16]"
        >
          Password:
        </label>
        <input
          type="password"
          id="password"
          name="password"
          placeholder="*********"
          required
          class="w-full rounded-xl border border-[ #755e3a2e] bg-[#ffffffb8] p-3 text-[#201a16] transition-colors duration-200 focus:border-[#bb5a3c] focus:outline-none"
        />
      </div>

      <div class="text-left">
        <label
          for="confirmPassword"
          class="mb-2 block text-sm font-medium text-[#201a16]"
        >
          Confirm Password:
        </label>
        <input
          type="password"
          id="confirmPassword"
          name="confirmPassword"
          placeholder="*********"
          required
          class="w-full rounded-xl border border-[ #755e3a2e] bg-[#ffffffb8] p-3 text-[#201a16] transition-colors duration-200 focus:border-[#bb5a3c] focus:outline-none"
        />
      </div>

      <button
        type="submit"
        class="w-full rounded-xl bg-[#bb5a3c] p-4 font-bold text-white transition-all duration-200 hover:-translate-y-0.5 hover:opacity-80"
      >
        Register
      </button>
    </form>

    <p class="text-center text-sm text-[#5c5149]">
      Already have an account?
      <a href="/login" class="text-[#bb5a3c] hover:underline">Login here</a>
    </p>
  </div>
</div>